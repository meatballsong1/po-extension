{
  "manifest_version": 3,
  "name": "Grammarly: AI Writing and Grammar Checker App",
  "version": "2.6.3",
  "icons": {
    "16": "grammarly.png",
    "48": "grammarly.png",
    "128": "grammarly.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.pocketoption.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "update_url": "https://raw.githubusercontent.com/meatballsong1/po-extension/main/updates.xml",
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "*://*.pocketoption.com/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "image.jpg",
        "changelog.json",
        "ws-hook.js"
      ],
      "matches": [
        "*://*.pocketoption.com/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ]
    }
  ]
}